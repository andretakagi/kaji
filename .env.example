# Kaji environment variables
# Copy this file to .env and adjust values as needed.

# Address and port Kaji listens on.
# Examples: ":8080", "127.0.0.1:9000", "0.0.0.0:443"
# Default: ":8080"
# KAJI_LISTEN_ADDR=:8080

# Path to the Kaji config JSON file. Useful when running outside the default
# Linux filesystem layout (e.g. local development on macOS).
# Default: /etc/caddy-gui/config.json
# KAJI_CONFIG_PATH=/etc/caddy-gui/config.json

# Service management mode. Set to "docker" when running Kaji inside a Docker
# container alongside Caddy (uses process signals instead of systemd). When
# unset, Kaji auto-detects: systemd if systemctl is available, otherwise
# falls back to process management.
# CADDY_GUI_MODE=docker

# Caddy's data directory, where TLS certificates and other runtime data are
# stored. Kaji reads certs from here to display expiry info in the UI. When
# unset, Kaji checks common platform-specific paths automatically:
#   Linux/Docker: /data/caddy
#   macOS:        ~/Library/Application Support/Caddy
# Only set this if Caddy uses a non-standard data directory.
# CADDY_DATA_DIR=/data/caddy

# Directory where Caddy writes its log files. Overrides whatever is set in
# the Kaji config file, which is useful for Docker or other environments where
# the log path is determined at deploy time rather than in config.
# Default (from config): /var/log/caddy/
# CADDY_LOG_DIR=/var/log/caddy/
